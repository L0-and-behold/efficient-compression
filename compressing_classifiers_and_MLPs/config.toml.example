"""
This file defines constants such as paths which need to be adjusted for the local machine.

SETUP INSTRUCTIONS:
1. Copy this file to `config.toml` (without the .example extension)
2. Update the paths below with your local machine's paths
3. The `config.toml` file is gitignored and will not be committed

The huggingface token is used in order to download the imagenet dataset from [huggingface](https://huggingface.co/) using the python script `installingImageNet/load_imagenet.py`
"""

[huggingface]
token = "YOUR_HF_TOKEN_HERE"

[paths]
imagenet_path = "/path/to/folder_containing_the_imagenet_dataset"
imagenet_preprocessed_path = "/path/to/folder_containing_the_pre_processed_imagenet_dataset"
path_to_db = "/path/to/save_results_here"